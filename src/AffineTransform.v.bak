module AffineTransform(AffineIn,AffineOut
    );
input [3:0]AffineIn;
output [3:0]AffineOut;

assign
AffineOut[3]=AffineIn[0],
AffineOut[2]=~AffineIn[1],
AffineOut[1]=~AffineIn[2],
AffineOut[0]=~(AffineIn[3]^AffineIn[0]);
endmodule
